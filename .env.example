# ---- Server ----
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/reltor

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- SendGrid (email) ----
# Leave SENDGRID_API_KEY blank to run in mock mode (emails are logged, not sent)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@yourbrokerage.com
SENDGRID_FROM_NAME=Your Brokerage

# ---- Meta / Facebook / Instagram Graph API ----
# Leave blank to run social posting in mock mode
META_GRAPH_VERSION=v19.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
